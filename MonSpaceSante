const RdvPatientTab = ({ user, toast }) => {
  const [medecins, setMedecins] = useState([]);
  const [mesRdv, setMesRdv] = useState([]);
  const [vue, setVue] = useState("liste_medecins"); // liste_medecins | mes_rdv
  const [medecinChoisi, setMedecinChoisi] = useState(null);
  const [search, setSearch] = useState("");

  const charger = () => {
    setMedecins(DB.get("mes_medecins"));
    setMesRdv(DB.get("mes_rdv").filter(r => r.patientId === user.id));
  };
  useEffect(() => { charger(); }, [user.id]);

  const demanderRdv = (form) => {
    const rdvList = DB.get("mes_rdv");
    const nouveau = {
      id: Date.now().toString(),
      patientId: user.id,
      patientNom: `${user.prenom} ${user.nom}`,
      patientTel: user.tel,
      medecinId: medecinChoisi.id,
      medecinNom: `${medecinChoisi.prenom} ${medecinChoisi.nom}`,
      medecinProfession: medecinChoisi.profession,
      date: form.date,
      heure: form.heure,
      motif: form.motif,
      type: form.type,
      statut: "en_attente",
      createdAt: new Date().toISOString(),
    };
    rdvList.push(nouveau);
    DB.set("mes_rdv", rdvList);
    setMedecinChoisi(null);
    charger();
    toast.add(`RDV demandé avec Dr. ${medecinChoisi.prenom} ${medecinChoisi.nom} le ${form.date} à ${form.heure}`, "success");
  };

  const annulerRdv = (id) => {
    const rdvList = DB.get("mes_rdv").map(r => r.id === id ? { ...r, statut: "annule" } : r);
    DB.set("mes_rdv", rdvList);
    charger();
    toast.add("Rendez-vous annulé", "info");
  };

  const filtresMed = medecins.filter(m =>
    `${m.prenom} ${m.nom} ${m.profession} ${m.hopital}`.toLowerCase().includes(search.toLowerCase())
  );

  const rdvAVenir = mesRdv.filter(r => r.statut !== "annule" && r.statut !== "termine");
  const rdvPasses = mesRdv.filter(r => r.statut === "termine" || r.statut === "annule");

  const typeLabel = { presentiel: "🏥 Présentiel", domicile: "🏠 À domicile", teleconsult: "📱 Téléconsultation" };

  return (
    <div>
      {medecinChoisi && (
        <RdvModal medecin={medecinChoisi} patient={user} onClose={()=>setMedecinChoisi(null)} onConfirm={demanderRdv} toast={toast}/>
      )}

      <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", marginBottom:20 }}>
        <h2 style={{ margin:0, fontSize:20, fontWeight:800, color:"#0f172a" }}>Rendez-vous</h2>
        <div style={{ display:"flex", gap:6 }}>
          {[{k:"liste_medecins",label:"Médecins"},{k:"mes_rdv",label:`Mes RDV (${rdvAVenir.length})`}].map(v=>(
            <button key={v.k} onClick={()=>setVue(v.k)} style={{ padding:"7px 14px", border:"none", borderRadius:20, cursor:"pointer", fontSize:12, fontWeight:700,
              background:vue===v.k?"#0ea5e9":"#e2e8f0", color:vue===v.k?"#fff":"#64748b" }}>
              {v.label}
            </button>
          ))}
        </div>
      </div>

      {vue === "liste_medecins" && (
        <>
          <input value={search} onChange={e=>setSearch(e.target.value)} placeholder="🔍 Rechercher un médecin..."
