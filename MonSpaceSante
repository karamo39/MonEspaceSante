const AuthModal = ({ role, onBack, onLogin, toast }) => {
  const [mode, setMode] = useState("login");
  const [form, setForm] = useState({});
  const [showPass, setShowPass] = useState(false);
  const set = (k,v) => setForm(p=>({...p,[k]:v}));

  const patientFields = [
    {k:"nom",label:"Nom",type:"text"},{k:"prenom",label:"Prénom",type:"text"},
    {k:"dob",label:"Date de naissance",type:"date"},{k:"quartier",label:"Quartier / Ville",type:"text"},
    {k:"tel",label:"Téléphone",type:"tel"},{k:"email",label:"Email (optionnel)",type:"email"},
    {k:"pin",label:"Code PIN",type:"password"},{k:"pin2",label:"Confirmer PIN",type:"password"},
  ];
  const medecinFields = [
    {k:"nom",label:"Nom",type:"text"},{k:"prenom",label:"Prénom",type:"text"},
    {k:"dob",label:"Date de naissance",type:"date"},{k:"lieu_naissance",label:"Lieu de naissance",type:"text"},
    {k:"profession",label:"Profession",type:"select",opts:["Médecin Généraliste","Médecin Spécialiste","Sage-femme","Infirmier(e)","Chirurgien","Pédiatre","Cardiologue","Gynécologue"]},
    {k:"experience",label:"Années d'expérience",type:"number"},{k:"hopital",label:"Hôpital / Clinique",type:"text"},
    {k:"email",label:"Email professionnel",type:"email"},{k:"tel",label:"Téléphone",type:"tel"},
    {k:"pin",label:"Mot de passe",type:"password"},{k:"pin2",label:"Confirmer mot de passe",type:"password"},
  ];
  const fields = role === "patient" ? patientFields : medecinFields;
  const colors = {patient:"#0ea5e9",medecin:"#10b981"};
  const color = colors[role]||"#8b5cf6";

  const register = () => {
    if (!form.nom||!form.prenom||!form.pin){toast.add("Veuillez remplir tous les champs requis","error");return;}
    if (form.pin!==form.pin2){toast.add("Les mots de passe ne correspondent pas","error");return;}
    const key = role==="patient"?"mes_patients":"mes_medecins";
    const list = DB.get(key);
    const id = Date.now().toString();
    const newUser = {...form,id,role,pin:hashPin(form.pin),createdAt:new Date().toISOString()};
    delete newUser.pin2;
    list.push(newUser);
    DB.set(key,list);
    toast.add(`Compte créé! Bienvenue ${form.prenom}`,"success");
    onLogin(newUser);
  };
  const login = () => {
    const key = role==="patient"?"mes_patients":"mes_medecins";
    const list = DB.get(key);
    const user = list.find(u=>(u.tel===form.identifier||u.email===form.identifier)&&u.pin===hashPin(form.pin));
    if(!user){toast.add("Identifiants incorrects","error");return;}
    toast.add(`Bienvenue ${user.prenom}!`,"success");
    onLogin(user);
  };

  return (
    <div style={{ minHeight:"100vh", background:"linear-gradient(160deg,#f0f9ff,#f0fdf4)", fontFamily:"'Outfit',sans-serif", display:"flex", flexDirection:"column" }}>
      <header style={{ background:"#fff", borderBottom:"1px solid #e2e8f0", padding:"14px 20px", display:"flex", alignItems:"center", gap:12 }}>
        <button onClick={onBack} style={{ background:"none", border:"none", cursor:"pointer", color:"#64748b", fontSize:14 }}>← Retour</button>
        <div style={{ width:36, height:36, background:`linear-gradient(135deg,${color},${color}cc)`, borderRadius:10, display:"flex", alignItems:"center", justifyContent:"center" }}>
          <Icon name={role==="patient"?"user":"stethoscope"} size={18} color="#fff"/>
        </div>
        <span style={{ fontWeight:700, color:"#0f172a" }}>Espace {role==="patient"?"Patient":"Médecin"}</span>
      </header>
      <div style={{ flex:1, display:"flex", alignItems:"center", justifyContent:"center", padding:20 }}>
        <div style={{ background:"#fff", borderRadius:24, padding:32, maxWidth:480, width:"100%", boxShadow:"0 4px 40px rgba(0,0,0,0.1)", maxHeight:"80vh", overflowY:"auto" }}>
          <div style={{ display:"flex", gap:0, marginBottom:28, background:"#f1f5f9", borderRadius:12, padding:4 }}>
            {["login","register"].map(m=>(
              <button key={m} onClick={()=>setMode(m)} style={{ flex:1, padding:"10px", border:"none", borderRadius:10, cursor:"pointer", fontSize:14, fontWeight:600, transition:"all 0.2s",
                background:mode===m?"#fff":"transparent", color:mode===m?color:"#64748b", boxShadow:mode===m?"0 2px 8px rgba(0,0,0,0.1)":"none" }}>
                {m==="login"?"Se connecter":"S'inscrire"}
              </button>
            ))}
          </div>
          {mode==="login" ? (
            <>
              <h2 style={{ margin:"0 0 20px", fontSize:22, fontWeight:800, color:"#0f172a" }}>Connexion</h2>
              <div style={{ marginBottom:14 }}>
                <label style={{ display:"block", fontSize:13, fontWeight:600, color:"#374151", marginBottom:6 }}>Téléphone ou Email</label>
                <input value={form.identifier||""} onChange={e=>set("identifier",e.target.value)} placeholder="628 000 000"
                  style={{ width:"100%", padding:"12px 16px", border:"2px solid #e2e8f0", borderRadius:10, fontSize:14, boxSizing:"border-box" }}/>
              </div>
              <div style={{ marginBottom:20, position:"relative" }}>
                <label style={{ display:"block", fontSize:13, fontWeight:600, color:"#374151", marginBottom:6 }}>Mot de passe</label>
                <input value={form.pin||""} onChange={e=>set("pin",e.target.value)} type={showPass?"text":"password"} placeholder="••••••••"
                  style={{ width:"100%", padding:"12px 40px 12px 16px", border:"2px solid #e2e8f0", borderRadius:10, fontSize:14, boxSizing:"border-box" }}/>
                <button onClick={()=>setShowPass(p=>!p)} style={{ position:"absolute", right:12, top:34, background:"none", border:"none", cursor:"pointer" }}>
                  <Icon name={showPass?"eyeoff":"eye"} size={16} color="#94a3b8"/>
                </button>
              </div>
              <button onClick={login} style={{ width:"100%", padding:"14px", border:"none", borderRadius:12, background:`linear-gradient(135deg,${color},${color}cc)`, color:"#fff", fontSize:16, fontWeight:700, cursor:"pointer" }}>
                Se connecter
              </button>
            </>
          ) : (
            <>
              <h2 style={{ margin:"0 0 20px", fontSize:22, fontWeight:800, color:"#0f172a" }}>Créer un compte</h2>
              <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:12 }}>
                {fields.map(f=>(
                  <div key={f.k} style={{ gridColumn:["dob","quartier","lieu_naissance","hopital","email","profession"].includes(f.k)?"1/-1":"auto" }}>
                    <label style={{ display:"block", fontSize:12, fontWeight:600, color:"#374151", marginBottom:4 }}>{f.label}</label>
                    {f.type==="select"
                      ? <select value={form[f.k]||""} onChange={e=>set(f.k,e.target.value)} style={{ width:"100%", padding:"10px 12px", border:"2px solid #e2e8f0", borderRadius:8, fontSize:13, background:"#fff" }}>
                          <option value="">Choisir...</option>
                          {f.opts.map(o=><option key={o} value={o}>{o}</option>)}
                        </select>
                      : <input value={form[f.k]||""} onChange={e=>set(f.k,e.target.value)} type={f.type}
                          style={{ width:"100%", padding:"10px 12px", border:"2px solid #e2e8f0", borderRadius:8, fontSize:13, boxSizing:"border-box" }}/>
                    }
                  </div>
                ))}
              </div>
              <div style={{ marginTop:16, padding:12, background:"#f0fdf4", borderRadius:10, border:"1px solid #bbf7d0", marginBottom:16 }}>
                <div style={{ fontSize:12, color:"#15803d", fontWeight:600, marginBottom:4 }}>📷 Photo d'identité</div>
                <input type="file" accept="image/*" onChange={e=>{
                  const file=e.target.files[0];
                  if(file){const r=new FileReader();r.onload=()=>set("photo",r.result);r.readAsDataURL(file);}
                }} style={{ fontSize:12, color:"#64748b" }}/>
              </div>
              <button onClick={register} style={{ width:"100%", padding:"14px", border:"none", borderRadius:12, background:`linear-gradient(135deg,${color},${color}cc)`, color:"#fff", fontSize:16, fontWeight:700, cursor:"pointer" }}>
                Créer mon compte
              </button>
            </>
          )}
        </div>
      </div>
    </div>
  );
};

