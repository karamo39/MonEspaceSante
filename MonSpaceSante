const RdvMedecinTab = ({ user, toast }) => {
  const [rdvList, setRdvList] = useState([]);
  const [filtre, setFiltre] = useState("tous");

  const charger = () => {
    setRdvList(DB.get("mes_rdv").filter(r => r.medecinId === user.id));
  };
  useEffect(() => { charger(); }, [user.id]);

  const changerStatut = (id, statut) => {
    const list = DB.get("mes_rdv").map(r => r.id === id ? { ...r, statut } : r);
    DB.set("mes_rdv", list);
    charger();
    const msgs = { confirme:"RDV confirmé ✓", annule:"RDV annulé", termine:"RDV marqué terminé" };
    toast.add(msgs[statut] || "Statut mis à jour", statut === "confirme" ? "success" : "info");
  };

  const filtres = [
    { k:"tous", label:"Tous" },
    { k:"en_attente", label:"En attente" },
    { k:"confirme", label:"Confirmés" },
    { k:"termine", label:"Terminés" },
    { k:"annule", label:"Annulés" },
  ];

  const affichage = filtre === "tous" ? rdvList : rdvList.filter(r => r.statut === filtre);
  const nbAttente = rdvList.filter(r => r.statut === "en_attente").length;
  const typeLabel = { presentiel:"🏥 Présentiel", domicile:"🏠 Domicile", teleconsult:"📱 Téléconsultation" };

  return (
    <div>
      <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", marginBottom:16 }}>
        <h2 style={{ margin:0, fontSize:20, fontWeight:800, color:"#0f172a" }}>Mes Rendez-vous</h2>
        {nbAttente > 0 && (
          <span style={{ background:"#ef4444", color:"#fff", borderRadius:100, padding:"3px 10px", fontSize:12, fontWeight:700 }}>
            {nbAttente} en attente
          </span>
        )}
      </div>

      {/* Filtres */}
      <div style={{ display:"flex", gap:6, overflowX:"auto", paddingBottom:4, marginBottom:18 }}>
        {filtres.map(f => (
          <button key={f.k} onClick={()=>setFiltre(f.k)} style={{ padding:"7px 14px", border:"none", borderRadius:20, cursor:"pointer", fontSize:12, fontWeight:700, whiteSpace:"nowrap",
            background:filtre===f.k?"#10b981":"#e2e8f0", color:filtre===f.k?"#fff":"#64748b" }}>
            {f.label}
          </button>
        ))}
      </div>

      {affichage.length === 0 ? (
        <div style={{ textAlign:"center", padding:48, color:"#94a3b8" }}>
          <Icon name="calendar" size={52} color="#cbd5e1"/>
          <p>Aucun rendez-vous {filtre !== "tous" ? `"${filtres.find(f=>f.k===filtre)?.label}"` : ""}</p>
        </div>
      ) : affichage.sort((a,b)=>new Date(a.date)-new Date(b.date)).map(r => (
        <div key={r.id} style={{ background:"#fff", borderRadius:16, padding:18, marginBottom:14, border:`2px solid ${r.statut==="en_attente"?"#fbbf24":r.statut==="confirme"?"#10b981":"#e2e8f0"}`, boxShadow:"0 2px 10px rgba(0,0,0,0.04)" }}>
          {/* En-tête patient */}
          <div style={{ display:"flex", gap:12, alignItems:"center", marginBottom:14 }}>
            <div style={{ width:44, height:44, background:"#0ea5e920", borderRadius:"50%", display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0 }}>
              <Icon name="user" size={20} color="#0ea5e9"/>
            </div>
            <div style={{ flex:1 }}>
              <div style={{ fontWeight:800, fontSize:15, color:"#0f172a" }}>{r.patientNom}</div>
              <div style={{ fontSize:12, color:"#64748b" }}>📞 {r.patientTel}</div>
            </div>
            <StatusBadge status={r.statut}/>
          </div>

          {/* Détails */}
          <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:8, marginBottom:14 }}>
            {[[<Icon name="calendar" size={13} color="#10b981"/>, new Date(r.date).toLocaleDateString("fr-FR",{weekday:"short",day:"numeric",month:"short"})],
              [<Icon name="clock" size={13} color="#10b981"/>, r.heure],
              [<span>🏷</span>, typeLabel[r.type] || r.type],
              [<Icon name="info" size={13} color="#10b981"/>, r.motif]
            ].map(([ic,txt],i)=>(
              <div key={i} style={{ display:"flex", alignItems:"center", gap:6, fontSize:12, color:"#374151", background:"#f8fafc", padding:"7px 10px", borderRadius:8 }}>
                {ic}<span>{txt}</span>
              </div>
            ))}
          </div>

          {/* Actions selon statut */}
          {r.statut === "en_attente" && (
            <div style={{ display:"flex", gap:8 }}>
              <button onClick={()=>changerStatut(r.id,"annule")} style={{ flex:1, padding:"10px", border:"2px solid #fecaca", borderRadius:10, background:"#fff5f5", color:"#ef4444", cursor:"pointer", fontSize:13, fontWeight:700 }}>
                ✗ Refuser
              </button>
              <button onClick={()=>changerStatut(r.id,"confirme")} style={{ flex:2, padding:"10px", border:"none", borderRadius:10, background:"linear-gradient(135deg,#10b981,#059669)", color:"#fff", cursor:"pointer", fontSize:13, fontWeight:700 }}>
                ✓ Confirmer le RDV
              </button>
            </div>
          )}
          {r.statut === "confirme" && (
            <div style={{ display:"flex", gap:8 }}>
              <a href={`tel:${r.patientTel}`} style={{ flex:1, padding:"10px", border:"2px solid #0ea5e9", borderRadius:10, background:"#e0f2fe", color:"#0284c7", cursor:"pointer", fontSize:13, fontWeight:700, textDecoration:"none", display:"flex", alignItems:"center", justifyContent:"center", gap:5 }}>
                <Icon name="phone" size={14} color="#0284c7"/> Appeler
              </a>
              <button onClick={()=>changerStatut(r.id,"termine")} style={{ flex:2, padding:"10px", border:"none", borderRadius:10, background:"linear-gradient(135deg,#6366f1,#4f46e5)", color:"#fff", cursor:"pointer", fontSize:13, fontWeight:700 }}>
                ✓ Marquer terminé
              </button>
            </div>
          )}
        </div>
      ))}
    </div>
  );
};

