      <header style={{ background:"#fff", borderBottom:"1px solid #e2e8f0", padding:"14px 20px", display:"flex", alignItems:"center", gap:12 }}>
        <button onClick={onBack} style={{ background:"none", border:"none", cursor:"pointer", color:"#64748b", fontSize:14 }}>← Retour</button>
        <div style={{ width:36, height:36, background:"linear-gradient(135deg,#8b5cf6,#7c3aed)", borderRadius:10, display:"flex", alignItems:"center", justifyContent:"center" }}><Icon name="phone" size={18} color="#fff"/></div>
        <div><div style={{ fontWeight:700, color:"#0f172a" }}>Espace Conseil</div><div style={{ fontSize:11, color:"#64748b" }}>Contactez un médecin</div></div>
      </header>
      <div style={{ maxWidth:680, margin:"0 auto", padding:"20px 16px" }}>
        {medecins.length===0 ? (
          <div style={{ textAlign:"center", padding:60, color:"#94a3b8" }}><Icon name="stethoscope" size={56} color="#cbd5e1"/><h3>Aucun médecin disponible</h3></div>
        ) : medecins.map(m=>(
          <div key={m.id} style={{ background:"#fff", borderRadius:16, padding:18, marginBottom:14, border:"1px solid #e2e8f0" }}>
            <div style={{ display:"flex", gap:14, marginBottom:16 }}>
              {m.photo?<img src={m.photo} style={{ width:56, height:56, borderRadius:"50%", objectFit:"cover", border:"2px solid #8b5cf6" }}/>:<div style={{ width:56, height:56, background:"#8b5cf620", borderRadius:"50%", display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0 }}><Icon name="user" size={26} color="#8b5cf6"/></div>}
              <div><div style={{ fontWeight:800, fontSize:16, color:"#0f172a" }}>Dr. {m.prenom} {m.nom}</div><div style={{ fontSize:13, color:"#8b5cf6", fontWeight:600 }}>{m.profession}</div><div style={{ fontSize:12, color:"#64748b" }}>{m.experience} ans · {m.hopital||"Clinique"}</div></div>
            </div>
            <div style={{ display:"flex", gap:8 }}>
              <button onClick={()=>startCall(m,"orange")} style={{ flex:1, padding:"10px", background:"#FF6B0015", border:"2px solid #FF6B00", borderRadius:10, cursor:"pointer", fontSize:12, fontWeight:700, color:"#FF6B00" }}>📱 Orange</button>
              <button onClick={()=>startCall(m,"mtn")} style={{ flex:1, padding:"10px", background:"#FFCC0015", border:"2px solid #FFCC00", borderRadius:10, cursor:"pointer", fontSize:12, fontWeight:700, color:"#b45309" }}>📱 MTN</button>
              {m.tel&&<a href={`tel:${m.tel}`} style={{ flex:1, padding:"10px", background:"#0ea5e915", border:"2px solid #0ea5e9", borderRadius:10, fontSize:12, fontWeight:700, color:"#0ea5e9", textDecoration:"none", display:"flex", alignItems:"center", justifyContent:"center" }}>☎️ Direct</a>}
            </div>
          </div>
        ))}
      </div>
    </div>
  );
};

// ─────────────────────────────────────────────
//  MAIN APP
// ─────────────────────────────────────────────
export default function MonEspaceSante() {
  const [screen, setScreen] = useState("landing");
  const [user, setUser] = useState(null);
  const toast = useToast();
  const handleLogin=(u)=>{setUser(u);setScreen(u.role==="patient"?"dashboard-patient":"dashboard-medecin");};
  const logout=()=>{setUser(null);setScreen("landing");};
  return (
    <div style={{ fontFamily:"'Outfit',sans-serif" }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&display=swap');
        * { box-sizing: border-box; } body { margin: 0; }
        @keyframes slideIn { from { transform: translateX(40px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        input:focus, textarea:focus, select:focus { outline: none; border-color: #0ea5e9 !important; }
        ::-webkit-scrollbar { width: 4px; } ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
      `}</style>
      <Toast toasts={toast.toasts} remove={toast.remove}/>
      {screen==="landing" && <LandingPage onSelect={role=>{ if(role==="conseil")setScreen("conseil"); else setScreen(`auth-${role}`); }}/>}
      {screen==="auth-patient" && <AuthModal role="patient" onBack={()=>setScreen("landing")} onLogin={handleLogin} toast={toast}/>}
      {screen==="auth-medecin" && <AuthModal role="medecin" onBack={()=>setScreen("landing")} onLogin={handleLogin} toast={toast}/>}
      {screen==="conseil" && <ConseilPublic onBack={()=>setScreen("landing")} toast={toast}/>}
      {screen==="dashboard-patient" && user && <PatientDashboard user={user} onLogout={logout} toast={toast}/>}
      {screen==="dashboard-medecin" && user && <MedecinDashboard user={user} onLogout={logout} toast={toast}/>}
    </div>
  );
}
